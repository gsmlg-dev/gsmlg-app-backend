<Layouts.privacy flash={@flash}>
  <section class="w-full h-full bg-neutral-900 text-slate-50 py-24">
    <header class="container px-6 mx-auto mb-8">
      <h1 class="text-center text-4xl">
        {dgettext("navigation", "Privacy Policy for Semaphore Client App")}
      </h1>
    </header>
    <div class="container px-6 mx-auto">
      <p class="my-2 text-lg">
        {dgettext("user", "At Semaphore Client App, we take your privacy seriously.")}
      </p>
      <h2 class="my-2 pt-2 font-bold text-slate-400 text-xl">
        {dgettext("navigation", "Information We Collect")}
      </h2>
      <p class="my-2 text-lg">
        {dgettext(
          "user",
          "When you use our app, you connect to your own server, the app does not collect anything."
        )}
      </p>
      <h2 class="my-2 pt-2 font-bold text-slate-400 text-xl">
        {dgettext("navigation", "Information Sharing and Disclosure")}
      </h2>
      <p class="my-2 text-lg">
        {dgettext(
          "user",
          "We do not sell, trade, or otherwise transfer your personal information to third parties. However, we may share your information with trusted third-party service providers who help us operate our app, conduct our business, or service you. We may also disclose your information when required by law, or when we believe in good faith that disclosure is necessary to protect our rights, protect your safety or the safety of others, or investigate fraud."
        )}
      </p>
      <h2 class="my-2 pt-2 font-bold text-slate-400 text-xl">
        {dgettext("navigation", "Security")}
      </h2>
      <p class="my-2 text-lg">
        {dgettext(
          "user",
          "We take reasonable precautions to protect the information we collect from unauthorized access, use, and disclosure. However, no method of transmission over the internet or electronic storage is 100% secure, so we cannot guarantee its absolute security."
        )}
      </p>
      <h2 class="my-2 pt-2 font-bold text-slate-400 text-xl">
        {dgettext("navigation", "Changes to this Privacy Policy")}
      </h2>
      <p class="my-2 text-lg">
        {dgettext(
          "user",
          "We reserve the right to modify this Privacy Policy at any time, so please review it frequently. If we make material changes to this policy, we will notify you here, by email, or by means of a notice on our app's homepage."
        )}
      </p>
      <h2 class="my-2 pt-2 font-bold text-slate-400 text-xl">
        {dgettext("navigation", "Contact Us")}
      </h2>
      <p class="my-2 text-lg">
        {dgettext(
          "user",
          "If you have any questions or concerns about this Privacy Policy, please contact us at"
        )} <email class="text-slate-300 font-semibold">support@gsmlg.app</email>.
      </p>
    </div>
  </section>
</Layouts.privacy>

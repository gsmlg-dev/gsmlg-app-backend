<div class="w-full min-h-[calc(100vh-3.5rem)] bg-base-100">
  <%= if @current_user do %>
    <%!-- Hero Welcome Banner --%>
    <div class="relative overflow-hidden bg-gradient-to-br from-primary/10 via-base-100 to-secondary/10">
      <div class="absolute inset-0 opacity-[0.03]"
           style="background-image: radial-gradient(circle at 1px 1px, currentColor 1px, transparent 0); background-size: 32px 32px;">
      </div>
      <div class="relative container mx-auto px-6 py-12 lg:py-16">
        <div class="flex items-end justify-between gap-8 flex-wrap">
          <div>
            <p class="text-sm font-medium tracking-[0.2em] uppercase text-primary/70 mb-2">
              Admin Dashboard
            </p>
            <h1 class="text-4xl lg:text-5xl font-black tracking-tight text-base-content">
              Welcome back
            </h1>
            <p class="mt-2 text-lg text-base-content/60 font-light">
              {@current_user.email}
            </p>
          </div>
          <div class="text-right text-sm text-base-content/40 font-mono">
            <p>GSMLG Platform</p>
            <p>v1.0</p>
          </div>
        </div>
      </div>
      <div class="h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>
    </div>

    <%!-- Dashboard Cards Grid --%>
    <div class="container mx-auto px-6 py-10">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

        <%!-- User Management Card --%>
        <.link href="/users" class="group block">
          <div class="relative h-full rounded-2xl border border-base-300/50 bg-base-100 p-6
                      transition-all duration-300 ease-out
                      hover:border-primary/40 hover:shadow-xl hover:shadow-primary/5
                      hover:-translate-y-1">
            <div class="flex items-start justify-between mb-6">
              <div class="flex items-center justify-center w-12 h-12 rounded-xl
                          bg-primary/10 text-primary
                          group-hover:bg-primary group-hover:text-primary-content
                          transition-colors duration-300">
                <.dm_mdi name="account-group" class="w-6 h-6" />
              </div>
              <.dm_mdi name="arrow-top-right" class="w-5 h-5 text-base-content/20
                        group-hover:text-primary group-hover:translate-x-0.5 group-hover:-translate-y-0.5
                        transition-all duration-300" />
            </div>
            <h3 class="text-xl font-bold text-base-content mb-2">
              User Management
            </h3>
            <p class="text-sm text-base-content/50 leading-relaxed">
              Manage user accounts, roles, and permissions. Create, edit, or deactivate users across the platform.
            </p>
            <div class="mt-6 pt-4 border-t border-base-300/30">
              <span class="text-xs font-medium tracking-wider uppercase text-primary/60
                           group-hover:text-primary transition-colors">
                Manage Users →
              </span>
            </div>
          </div>
        </.link>

        <%!-- Apps Management Card --%>
        <.link href="/apps" class="group block">
          <div class="relative h-full rounded-2xl border border-base-300/50 bg-base-100 p-6
                      transition-all duration-300 ease-out
                      hover:border-secondary/40 hover:shadow-xl hover:shadow-secondary/5
                      hover:-translate-y-1">
            <div class="flex items-start justify-between mb-6">
              <div class="flex items-center justify-center w-12 h-12 rounded-xl
                          bg-secondary/10 text-secondary
                          group-hover:bg-secondary group-hover:text-secondary-content
                          transition-colors duration-300">
                <.dm_mdi name="apps" class="w-6 h-6" />
              </div>
              <.dm_mdi name="arrow-top-right" class="w-5 h-5 text-base-content/20
                        group-hover:text-secondary group-hover:translate-x-0.5 group-hover:-translate-y-0.5
                        transition-all duration-300" />
            </div>
            <h3 class="text-xl font-bold text-base-content mb-2">
              Apps Management
            </h3>
            <p class="text-sm text-base-content/50 leading-relaxed">
              Publish and organize applications. Manage store links, display order, and platform availability.
            </p>
            <div class="mt-6 pt-4 border-t border-base-300/30">
              <span class="text-xs font-medium tracking-wider uppercase text-secondary/60
                           group-hover:text-secondary transition-colors">
                Manage Apps →
              </span>
            </div>
          </div>
        </.link>

        <%!-- AI Provider Card --%>
        <.link href="/ai-provider/providers" class="group block">
          <div class="relative h-full rounded-2xl border border-base-300/50 bg-base-100 p-6
                      transition-all duration-300 ease-out
                      hover:border-accent/40 hover:shadow-xl hover:shadow-accent/5
                      hover:-translate-y-1">
            <div class="flex items-start justify-between mb-6">
              <div class="flex items-center justify-center w-12 h-12 rounded-xl
                          bg-accent/10 text-accent
                          group-hover:bg-accent group-hover:text-accent-content
                          transition-colors duration-300">
                <.dm_mdi name="robot" class="w-6 h-6" />
              </div>
              <.dm_mdi name="arrow-top-right" class="w-5 h-5 text-base-content/20
                        group-hover:text-accent group-hover:translate-x-0.5 group-hover:-translate-y-0.5
                        transition-all duration-300" />
            </div>
            <h3 class="text-xl font-bold text-base-content mb-2">
              AI Providers
            </h3>
            <p class="text-sm text-base-content/50 leading-relaxed">
              Configure LLM providers, API keys, and model settings. Monitor usage and manage gateway access.
            </p>
            <div class="mt-6 pt-4 border-t border-base-300/30">
              <span class="text-xs font-medium tracking-wider uppercase text-accent/60
                           group-hover:text-accent transition-colors">
                Configure AI →
              </span>
            </div>
          </div>
        </.link>

      </div>

      <%!-- AI Provider Quick Links --%>
      <div class="mt-10">
        <h2 class="text-xs font-semibold tracking-[0.15em] uppercase text-base-content/40 mb-4">
          AI Provider Settings
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
          <.link href="/ai-provider/api-keys"
                 class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-base-200/50 border border-transparent
                        hover:bg-base-200 hover:border-base-300/50
                        transition-all duration-200">
            <.dm_mdi name="key-variant" class="w-4 h-4 text-base-content/30 group-hover:text-primary transition-colors" />
            <span class="text-sm text-base-content/60 group-hover:text-base-content transition-colors">API Keys</span>
          </.link>

          <.link href="/ai-provider/system-prompts"
                 class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-base-200/50 border border-transparent
                        hover:bg-base-200 hover:border-base-300/50
                        transition-all duration-200">
            <.dm_mdi name="text-box-outline" class="w-4 h-4 text-base-content/30 group-hover:text-primary transition-colors" />
            <span class="text-sm text-base-content/60 group-hover:text-base-content transition-colors">Prompts</span>
          </.link>

          <.link href="/ai-provider/memories"
                 class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-base-200/50 border border-transparent
                        hover:bg-base-200 hover:border-base-300/50
                        transition-all duration-200">
            <.dm_mdi name="brain" class="w-4 h-4 text-base-content/30 group-hover:text-primary transition-colors" />
            <span class="text-sm text-base-content/60 group-hover:text-base-content transition-colors">Memories</span>
          </.link>

          <.link href="/ai-provider/tools"
                 class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-base-200/50 border border-transparent
                        hover:bg-base-200 hover:border-base-300/50
                        transition-all duration-200">
            <.dm_mdi name="wrench" class="w-4 h-4 text-base-content/30 group-hover:text-primary transition-colors" />
            <span class="text-sm text-base-content/60 group-hover:text-base-content transition-colors">Tools</span>
          </.link>

          <.link href="/ai-provider/agents"
                 class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-base-200/50 border border-transparent
                        hover:bg-base-200 hover:border-base-300/50
                        transition-all duration-200">
            <.dm_mdi name="robot-outline" class="w-4 h-4 text-base-content/30 group-hover:text-primary transition-colors" />
            <span class="text-sm text-base-content/60 group-hover:text-base-content transition-colors">Agents</span>
          </.link>

          <.link href="/ai-provider/usage"
                 class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-base-200/50 border border-transparent
                        hover:bg-base-200 hover:border-base-300/50
                        transition-all duration-200">
            <.dm_mdi name="chart-bar" class="w-4 h-4 text-base-content/30 group-hover:text-primary transition-colors" />
            <span class="text-sm text-base-content/60 group-hover:text-base-content transition-colors">Usage</span>
          </.link>
        </div>
      </div>
    </div>

  <% else %>
    <%!-- Unauthenticated State --%>
    <div class="flex flex-col items-center justify-center min-h-[calc(100vh-3.5rem)] px-6">
      <div class="relative">
        <div class="absolute -inset-8 bg-primary/5 rounded-full blur-3xl"></div>
        <div class="relative text-center max-w-md">
          <div class="w-16 h-16 mx-auto mb-6 rounded-2xl bg-primary/10 flex items-center justify-center">
            <.dm_mdi name="shield-lock" class="w-8 h-8 text-primary" />
          </div>
          <h1 class="text-3xl font-black tracking-tight text-base-content mb-3">
            GSMLG Admin
          </h1>
          <p class="text-base-content/50 mb-8 leading-relaxed">
            Sign in to access the administration panel and manage platform resources.
          </p>
          <.link href="/sign-in" class="btn btn-primary btn-lg gap-2">
            <.dm_mdi name="login" class="w-5 h-5" />
            Sign In
          </.link>
        </div>
      </div>
    </div>
  <% end %>
</div>

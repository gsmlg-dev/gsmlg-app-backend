<div class="w-full min-h-[calc(100vh-3.5rem)] bg-surface text-on-surface">
  <%= if @current_user do %>
    <%!-- Hero Welcome Banner --%>
    <section class="bg-primary-container text-on-primary-container">
      <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
        <div class="flex items-end justify-between gap-8 flex-wrap">
          <div>
            <p class="text-sm font-semibold uppercase tracking-wider text-primary">
              Admin Dashboard
            </p>
            <h1 class="mt-2 text-4xl font-bold tracking-tight lg:text-5xl">
              Welcome back
            </h1>
            <p class="mt-2 text-lg text-on-primary-container/80">
              {@current_user.email}
            </p>
          </div>
          <div class="text-right text-sm font-mono text-on-primary-container/70">
            <p>GSMLG Platform</p>
            <p>v1.0</p>
          </div>
        </div>
      </div>
    </section>

    <%!-- Dashboard Cards Grid --%>
    <div class="mx-auto max-w-7xl px-4 py-10 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        <%!-- User Management Card --%>
        <.link href="/users" class="group block">
          <div class="relative h-full rounded-lg border border-outline-variant bg-surface-container p-6
                      transition-all duration-300 ease-out
                      hover:border-primary hover:bg-surface-container-high hover:shadow-lg
                      hover:-translate-y-1">
            <div class="flex items-start justify-between mb-6">
              <div class="flex items-center justify-center w-12 h-12 rounded-lg
                          bg-primary text-primary-content
                          transition-colors duration-300">
                <.dm_mdi name="account-group" class="w-6 h-6" />
              </div>
              <.dm_mdi
                name="arrow-top-right"
                class="w-5 h-5 text-on-surface-variant
                        group-hover:text-primary group-hover:translate-x-0.5 group-hover:-translate-y-0.5
                        transition-all duration-300"
              />
            </div>
            <h3 class="text-xl font-semibold text-on-surface mb-2">
              User Management
            </h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              Manage user accounts, roles, and permissions. Create, edit, or deactivate users across the platform.
            </p>
            <div class="mt-6 pt-4 border-t border-outline-variant">
              <span class="text-xs font-semibold tracking-wider uppercase text-primary
                           group-hover:text-primary transition-colors">
                Manage Users →
              </span>
            </div>
          </div>
        </.link>

        <%!-- Apps Management Card --%>
        <.link href="/apps" class="group block">
          <div class="relative h-full rounded-lg border border-outline-variant bg-surface-container p-6
                      transition-all duration-300 ease-out
                      hover:border-secondary hover:bg-surface-container-high hover:shadow-lg
                      hover:-translate-y-1">
            <div class="flex items-start justify-between mb-6">
              <div class="flex items-center justify-center w-12 h-12 rounded-lg
                          bg-secondary text-secondary-content
                          transition-colors duration-300">
                <.dm_mdi name="apps" class="w-6 h-6" />
              </div>
              <.dm_mdi
                name="arrow-top-right"
                class="w-5 h-5 text-on-surface-variant
                        group-hover:text-secondary group-hover:translate-x-0.5 group-hover:-translate-y-0.5
                        transition-all duration-300"
              />
            </div>
            <h3 class="text-xl font-semibold text-on-surface mb-2">
              Apps Management
            </h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              Publish and organize applications. Manage store links, display order, and platform availability.
            </p>
            <div class="mt-6 pt-4 border-t border-outline-variant">
              <span class="text-xs font-semibold tracking-wider uppercase text-secondary
                           group-hover:text-secondary transition-colors">
                Manage Apps →
              </span>
            </div>
          </div>
        </.link>

        <%!-- AI Provider Card --%>
        <.link href="/ai-provider/providers" class="group block">
          <div class="relative h-full rounded-lg border border-outline-variant bg-surface-container p-6
                      transition-all duration-300 ease-out
                      hover:border-tertiary hover:bg-surface-container-high hover:shadow-lg
                      hover:-translate-y-1">
            <div class="flex items-start justify-between mb-6">
              <div class="flex items-center justify-center w-12 h-12 rounded-lg
                          bg-tertiary text-tertiary-content
                          transition-colors duration-300">
                <.dm_mdi name="robot" class="w-6 h-6" />
              </div>
              <.dm_mdi
                name="arrow-top-right"
                class="w-5 h-5 text-on-surface-variant
                        group-hover:text-tertiary group-hover:translate-x-0.5 group-hover:-translate-y-0.5
                        transition-all duration-300"
              />
            </div>
            <h3 class="text-xl font-semibold text-on-surface mb-2">
              AI Providers
            </h3>
            <p class="text-sm text-on-surface-variant leading-relaxed">
              Configure LLM providers, API keys, and model settings. Monitor usage and manage gateway access.
            </p>
            <div class="mt-6 pt-4 border-t border-outline-variant">
              <span class="text-xs font-semibold tracking-wider uppercase text-tertiary
                           group-hover:text-tertiary transition-colors">
                Configure AI →
              </span>
            </div>
          </div>
        </.link>
      </div>

      <%!-- AI Provider Quick Links --%>
      <div class="mt-10">
        <h2 class="text-xs font-semibold tracking-wider uppercase text-on-surface-variant mb-4">
          AI Provider Settings
        </h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
          <.link
            href="/ai-provider/api-keys"
            class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-surface-container border border-transparent
                        hover:bg-surface-container-high hover:border-outline-variant
                        transition-all duration-200"
          >
            <.dm_mdi
              name="key-variant"
              class="w-4 h-4 text-on-surface-variant group-hover:text-primary transition-colors"
            />
            <span class="text-sm text-on-surface-variant group-hover:text-on-surface transition-colors">
              API Keys
            </span>
          </.link>

          <.link
            href="/ai-provider/system-prompts"
            class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-surface-container border border-transparent
                        hover:bg-surface-container-high hover:border-outline-variant
                        transition-all duration-200"
          >
            <.dm_mdi
              name="text-box-outline"
              class="w-4 h-4 text-on-surface-variant group-hover:text-primary transition-colors"
            />
            <span class="text-sm text-on-surface-variant group-hover:text-on-surface transition-colors">
              Prompts
            </span>
          </.link>

          <.link
            href="/ai-provider/memories"
            class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-surface-container border border-transparent
                        hover:bg-surface-container-high hover:border-outline-variant
                        transition-all duration-200"
          >
            <.dm_mdi
              name="brain"
              class="w-4 h-4 text-on-surface-variant group-hover:text-primary transition-colors"
            />
            <span class="text-sm text-on-surface-variant group-hover:text-on-surface transition-colors">
              Memories
            </span>
          </.link>

          <.link
            href="/ai-provider/tools"
            class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-surface-container border border-transparent
                        hover:bg-surface-container-high hover:border-outline-variant
                        transition-all duration-200"
          >
            <.dm_mdi
              name="wrench"
              class="w-4 h-4 text-on-surface-variant group-hover:text-primary transition-colors"
            />
            <span class="text-sm text-on-surface-variant group-hover:text-on-surface transition-colors">
              Tools
            </span>
          </.link>

          <.link
            href="/ai-provider/agents"
            class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-surface-container border border-transparent
                        hover:bg-surface-container-high hover:border-outline-variant
                        transition-all duration-200"
          >
            <.dm_mdi
              name="robot-outline"
              class="w-4 h-4 text-on-surface-variant group-hover:text-primary transition-colors"
            />
            <span class="text-sm text-on-surface-variant group-hover:text-on-surface transition-colors">
              Agents
            </span>
          </.link>

          <.link
            href="/ai-provider/usage"
            class="group flex items-center gap-2 px-4 py-3 rounded-xl
                        bg-surface-container border border-transparent
                        hover:bg-surface-container-high hover:border-outline-variant
                        transition-all duration-200"
          >
            <.dm_mdi
              name="chart-bar"
              class="w-4 h-4 text-on-surface-variant group-hover:text-primary transition-colors"
            />
            <span class="text-sm text-on-surface-variant group-hover:text-on-surface transition-colors">
              Usage
            </span>
          </.link>
        </div>
      </div>
    </div>
  <% else %>
    <%!-- Unauthenticated State --%>
    <div class="flex flex-col items-center justify-center min-h-[calc(100vh-3.5rem)] px-6">
      <div class="max-w-md rounded-lg border border-outline-variant bg-surface-container p-8 text-center shadow-lg">
        <div class="w-16 h-16 mx-auto mb-6 rounded-lg bg-primary text-primary-content flex items-center justify-center">
          <.dm_mdi name="shield-lock" class="w-8 h-8" />
        </div>
        <h1 class="text-3xl font-bold tracking-tight text-on-surface mb-3">
          GSMLG Admin
        </h1>
        <p class="text-on-surface-variant mb-8 leading-relaxed">
          Sign in to access the administration panel and manage platform resources.
        </p>
        <.link href="/sign-in" class="btn btn-primary btn-lg gap-2">
          <.dm_mdi name="login" class="w-5 h-5" /> Sign In
        </.link>
      </div>
    </div>
  <% end %>
</div>

<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]" data-theme="sunshine">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title suffix=" · GSMLG Admin">
      {assigns[:page_title] || "GSMLG Admin"}
    </.live_title>
    <link
      phx-track-static
      rel="stylesheet"
      href={
        DuskmoonBundler.static_path(
          GsmlgAppAdminWeb.Endpoint,
          "/assets/css/app.css",
          profile: :gsmlg_app_admin_web
        )
      }
    />
    <script type="importmap">
      {
        "imports": {
          "@duskmoon-dev/el-base": "/assets/vendor/duskmoon/el-base.js",
          "@duskmoon-dev/core/components/markdown-body": "/assets/vendor/duskmoon/markdown-body.js"
        }
      }
    </script>
    <script
      defer
      phx-track-static
      type="module"
      src="/assets/vendor/duskmoon/el-markdown-register.js"
    >
    </script>
    <script
      defer
      phx-track-static
      type="module"
      src={
        DuskmoonBundler.static_path(
          GsmlgAppAdminWeb.Endpoint,
          "/assets/js/app.js",
          profile: :gsmlg_app_admin_web
        )
      }
    >
    </script>
    <script>
      // Apply saved theme immediately to prevent flash
      (function() {
        var theme = localStorage.getItem("theme") || "sunshine";
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body class="relative flex flex-col">
    {@inner_content}
  </body>
</html>

<.ai_provider_layout current_path={@current_uri}>
  <div class="p-4 sm:p-6">
    <div class="mb-6 flex items-center justify-between">
      <h1 class="text-3xl font-semibold leading-8 text-on-surface">API Usage Logs</h1>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
      <div class="rounded-lg border border-outline-variant bg-surface-container p-4 shadow-sm">
        <div class="text-sm text-on-surface-variant">Total Requests</div>
        <div class="text-2xl font-bold">{@summary.total_requests}</div>
      </div>
      <div class="rounded-lg border border-outline-variant bg-surface-container p-4 shadow-sm">
        <div class="text-sm text-on-surface-variant">Total Tokens</div>
        <div class="text-2xl font-bold">{@summary.total_tokens}</div>
        <div class="text-xs text-on-surface-variant">
          {@summary.total_prompt_tokens} prompt / {@summary.total_completion_tokens} completion
        </div>
      </div>
      <div class="rounded-lg border border-outline-variant bg-surface-container p-4 shadow-sm">
        <div class="text-sm text-on-surface-variant">Success</div>
        <div class="text-2xl font-bold text-success">{@summary.success_count}</div>
      </div>
      <div class="rounded-lg border border-outline-variant bg-surface-container p-4 shadow-sm">
        <div class="text-sm text-on-surface-variant">Errors</div>
        <div class="text-2xl font-bold text-error">{@summary.error_count}</div>
      </div>
    </div>

    <div :if={@summary.by_endpoint != %{}} class="mb-6">
      <h2 class="text-lg font-semibold mb-2">By Endpoint</h2>
      <div class="flex flex-wrap gap-2">
        <span :for={{endpoint, count} <- @summary.by_endpoint} class="badge badge-outline gap-1">
          {endpoint} <span class="badge badge-sm badge-neutral">{count}</span>
        </span>
      </div>
    </div>

    <div :if={@summary.by_model != %{}} class="mb-6">
      <h2 class="text-lg font-semibold mb-2">By Model</h2>
      <div class="flex flex-wrap gap-2">
        <span :for={{model, count} <- @summary.by_model} class="badge badge-outline gap-1">
          {model} <span class="badge badge-sm badge-neutral">{count}</span>
        </span>
      </div>
    </div>

    <div class="overflow-x-auto">
      <table class="table table-sm w-full">
        <thead>
          <tr>
            <th>Time</th>
            <th>Endpoint</th>
            <th>Model</th>
            <th>Tokens</th>
            <th>Duration</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <tr :for={log <- @logs} id={"log-#{log.id}"}>
            <td class="text-xs">{Calendar.strftime(log.created_at, "%Y-%m-%d %H:%M:%S")}</td>
            <td><span class="badge badge-sm badge-outline">{log.endpoint_type}</span></td>
            <td class="text-sm">{log.model}</td>
            <td class="text-sm">
              <span class="opacity-70">{log.prompt_tokens}+{log.completion_tokens}=</span>{log.total_tokens}
            </td>
            <td class="text-sm">
              {if log.duration_ms, do: "#{log.duration_ms}ms", else: "-"}
            </td>
            <td>
              <span class={[
                "badge badge-sm",
                case log.status do
                  :success -> "badge-success"
                  :error -> "badge-error"
                  :rate_limited -> "badge-warning"
                  _ -> ""
                end
              ]}>
                {log.status}
              </span>
            </td>
          </tr>
        </tbody>
      </table>
    </div>

    <div :if={@logs == []} class="py-8 text-center text-on-surface-variant">
      No usage logs yet.
    </div>
  </div>
</.ai_provider_layout>

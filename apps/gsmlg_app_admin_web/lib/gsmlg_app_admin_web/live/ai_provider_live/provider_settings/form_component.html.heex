<div>
  <.dm_card>
    <:title>{@title}</:title>
    <.dm_form
      :let={f}
      for={@form}
      id="provider-form"
      phx-target={@myself}
      phx-change="validate"
      phx-submit="save"
    >
      <.dm_input
        field={f[:name]}
        type="text"
        label="Name"
        placeholder="My AI Provider"
        required
      />

      <.dm_input
        field={f[:slug]}
        type="text"
        label="Slug"
        placeholder="my-provider"
        disabled={@action == :edit}
        required
      />

      <.dm_input
        field={f[:api_base_url]}
        type="text"
        label="API Base URL"
        placeholder="https://api.example.com/v1"
        required
      />

      <.dm_input
        field={f[:api_key]}
        type="password"
        label="API Key"
        placeholder={if @action == :edit, do: "Leave blank to keep current", else: "sk-..."}
        autocomplete="off"
      />

      <.dm_input
        field={f[:model]}
        type="text"
        label="Default Model"
        placeholder="gpt-4"
        required
      />

      <.dm_input
        field={f[:description]}
        type="textarea"
        label="Description"
        placeholder="Optional description of this provider"
      />

      <.dm_input
        field={f[:is_active]}
        type="checkbox"
        label="Active"
      />

      <:actions>
        <.dm_btn phx-disable-with="Saving...">Save Provider</.dm_btn>
      </:actions>
    </.dm_form>
  </.dm_card>
</div>

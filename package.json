{
  "name": "gsmlg-app-backend",
  "version": "1.0.0",
  "private": true,
  "description": "GSMLG App Backend - Umbrella Project",
  "workspaces": [
    "apps/gsmlg_app_web",
    "apps/gsmlg_app_admin_web"
  ],
  "scripts": {
    "setup": "npm run setup:web && npm run setup:admin",
    "setup:web": "cd apps/gsmlg_app_web && npm install",
    "setup:admin": "cd apps/gsmlg_app_admin_web && npm install",
    "build": "npm run build:web && npm run build:admin",
    "build:web": "cd apps/gsmlg_app_web && npm run build",
    "build:admin": "cd apps/gsmlg_app_admin_web && npm run build",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:admin\"",
    "dev:web": "cd apps/gsmlg_app_web && npm run dev",
    "dev:admin": "cd apps/gsmlg_app_admin_web && npm run dev",
    "format": "mix format",
    "test": "mix cmd mix test",
    "lint": "mix format --check-formatted"
  },
  "author": "Jonathan Gao",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}